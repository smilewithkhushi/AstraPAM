# AegisPAM — environment variable reference
# Copy to .env and fill in values. Never commit .env.

# Mock CBS base URL (second uvicorn process)
CBS_URL=http://localhost:8001

# SQLite database path
DB_PATH=database/aegispam.db

# Main control API
API_HOST=0.0.0.0
API_PORT=8000

# AstraPAM FastAPI backend URL (set this in Streamlit Cloud secrets / Railway env)
# Local:
# API_URL=http://localhost:8000
# Railway (production):
API_URL=https://astrapam.up.railway.app

# Ephemeral grant TTL in seconds
GRANT_TTL_SECONDS=300

# Risk thresholds (0–1) — maps score to decision
RISK_THRESHOLD_THROTTLE=0.40
RISK_THRESHOLD_STEP_UP=0.65
RISK_THRESHOLD_DENY=0.80

# Reconciliation SLA window — financial actions unmatched after this many seconds are flagged
RECON_SLA_SECONDS=30
